---
import { timeline } from '../data/artist';
---

<section id="timeline" class="py-24 px-6 bg-muted texture-diagonal">
  <div class="relative z-10 max-w-4xl mx-auto">

    <!-- Header -->
    <div class="reveal mb-16">
      <p class="font-mono text-[10px] uppercase tracking-[0.3em] text-muted-fg mb-3">History</p>
      <h2 class="font-display text-4xl sm:text-5xl font-bold tracking-tight">大事年表</h2>
    </div>

    <div class="relative">
      <!-- Vertical line -->
      <div
        class="absolute left-[92px] sm:left-[110px] top-0 bottom-0 w-px bg-black/20"
        aria-hidden="true"
      ></div>

      <div class="space-y-0">
        {timeline.map((item, i) => (
          <div
            class="reveal group flex gap-6 sm:gap-10 py-7 border-b border-black/10 last:border-b-0"
            data-delay={String(i * 70)}
          >
            <!-- Year label -->
            <div class="w-20 sm:w-24 flex-shrink-0 text-right self-start pt-0.5">
              <span class="font-display text-base font-bold">
                {item.year}
              </span>
            </div>

            <!-- Square marker — architectural, not a dot -->
            <div class="relative flex-shrink-0 mt-2">
              <div
                class="w-3 h-3 border-2 border-black bg-white group-hover:bg-black transition-colors duration-100"
                aria-hidden="true"
              ></div>
            </div>

            <!-- Events -->
            <div class="flex-1 space-y-2 self-start">
              {item.events.map(ev => (
                <p class="font-body text-base leading-relaxed">{ev}</p>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- End node -->
      <div class="flex gap-6 sm:gap-10 pt-8">
        <div class="w-20 sm:w-24 flex-shrink-0 text-right self-start">
          <span class="font-mono text-[10px] uppercase tracking-widest text-muted-fg">Now</span>
        </div>
        <div class="relative flex-shrink-0 mt-1">
          <!-- Hollow pulsing square for "ongoing" -->
          <div class="w-3 h-3 border-2 border-black animate-pulse"></div>
        </div>
        <p class="font-mono text-xs text-muted-fg tracking-wide self-start mt-0.5">
          Continuing...
        </p>
      </div>
    </div>
  </div>
</section>

<div class="rule-4"></div>
